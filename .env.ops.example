# FastAPI ops API settings.
PROMETHEUS_URL=http://172.30.1.240
PROMETHEUS_HOST_HEADER=prometheus.homelab.local
PROXMOX_URL=https://172.30.1.12:8006
PROXMOX_VERIFY_TLS=false

# Preferred Proxmox auth: API token.
# Example token id format: root@pam!portfolio-dashboard
PVE_API_TOKEN_ID=
PVE_API_TOKEN_SECRET=

# Alternative Proxmox auth: username/password ticket.
# PVE_USERNAME=root@pam
# PVE_PASSWORD=

OPS_API_HOST=127.0.0.1
OPS_API_PORT=18081
OPS_API_CORS_ORIGINS=https://mint-cocoa.github.io
