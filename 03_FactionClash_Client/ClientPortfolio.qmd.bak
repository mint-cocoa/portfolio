    subgraph Core["Core Layer"]
        App["App<br/>(시스템 통합)"]:::core
        DX["DX11Device<br/>(SwapChain·RTV·DSV)"]:::core
        Input["Input<br/>(키·마우스 상태)"]:::core
    end

    subgraph Renderer["Renderer Layer"]
        Pipe["Pipeline<br/>(VS·PS·CB)"]:::render
