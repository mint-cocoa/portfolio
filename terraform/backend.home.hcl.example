bucket       = "homelab-terraform-state"
key          = "portfolio/proxmox-kubernetes-ha/terraform.tfstate"
region       = "us-east-1"
encrypt      = true
use_lockfile = true

# For AWS S3, remove this block and use the normal AWS endpoint.
# For MinIO, Garage, SeaweedFS, or another S3-compatible backend, keep it.
endpoints = {
  s3 = "https://s3.home.example"
}
use_path_style              = true
skip_credentials_validation = true
skip_metadata_api_check     = true
skip_region_validation      = true
skip_requesting_account_id  = true

# Optional when the backend is AWS S3 with KMS.
# kms_key_id = "arn:aws:kms:us-east-1:111122223333:key/00000000-0000-0000-0000-000000000000"
